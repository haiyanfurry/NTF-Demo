; ============================================
; Hello World 测试用 CPU 定义
; ============================================
; 此文件修复了字段定义在指令之前的问题
; 编码格式 (单字节指令):
;   Byte: [7:4] = opcode, [3:2] = dst, [1:0] = src
;   多字节指令: 首字节全匹配 + 后续字节
; ============================================

; --- 全局配置 ---
arch "test-hello"
endian little
insn_size variable

; ============================================
; 操作数字段定义 (必须放在指令之前)
; ============================================

; 目的寄存器字段 [3:2]
字段 dst       bits=3:2
    ax         value=00
    bx         value=01
    cx         value=10
    dx         value=11

; 源操作数字段 [1:0]
字段 src       bits=1:0
    ax         value=00
    bx         value=01
    imm_1      value=10
    imm_5      value=11

; 立即数字段 [7:0]
字段 imm_val   bits=7:0  type=immediate

; ============================================
; 指令编码表
; ============================================

; 单字节指令
指令 nop       mask=0xFF pattern=0x00
指令 print     mask=0xFF pattern=0x01  operands=imm_val  size=2
指令 waitkey   mask=0xFF pattern=0x02
指令 exit      mask=0xFF pattern=0xFF

; 带寄存器操作数的指令
指令 mov       mask=0xF0 pattern=0x10  operands=dst,src
指令 add       mask=0xF0 pattern=0x20  operands=dst,src
