; ============================================
; 旧版 .01 格式兼容 CPU 定义
; ============================================
; 本文件提供对 NTF-Demo v1.x 的 .01 文本格式的向上兼容。
; .01 格式每行以文本方式表示二进制操作码:
;   "00000" → nop
;   "00001 reg1 reg2" → mov
;   ...
;
; 由于 .01 格式本质上是文本 ASCII 编码，
; 本头文件将 ASCII 字符的 bit 模式映射为汇编指令。
; 注意: 这只是一个概念示例，实际兼容性通过 -t 模式实现。
; ============================================

arch "ntf-legacy-compat"
endian little
insn_size variable

; 旧版指令使用 5 位二进制文本作为操作码
; 在 -t 模式下，输入解析器直接读取文本 token
; 以下为使用 8 位数据格式的近似映射:

; 将每个 .01 指令编码为1-3字节:
; Byte0: 固定操作码标识
; Byte1+: 操作数字段

指令 nop       mask=0xFF pattern=0x00
指令 mov       mask=0xF0 pattern=0x10  operands=mreg1,mreg2  size=3
指令 add       mask=0xF0 pattern=0x20  operands=mreg1,mreg2  size=3
指令 sub       mask=0xF0 pattern=0x30  operands=mreg1,mreg2  size=3
指令 mul       mask=0xF0 pattern=0x40  operands=mreg1,mreg2  size=3
指令 inc       mask=0xF0 pattern=0x50  operands=mreg1  size=2
指令 dec       mask=0xF0 pattern=0x60  operands=mreg1  size=2
指令 xor       mask=0xF0 pattern=0x70  operands=mreg1,mreg2  size=3
指令 jmp       mask=0xFF pattern=0x80  operands=mlabel  size=3
指令 push      mask=0xFF pattern=0x90  operands=mreg1  size=2
指令 pop       mask=0xFF pattern=0xA0  operands=mreg1  size=2

; 操作数编码 (使用旧版 00x 编码)
字段 mreg1     bits=7:0
    ax         value=0x01
    bx         value=0x02
    cx         value=0x03
    dx         value=0x04
    imm_0      value=0x00
    imm_1      value=0x17
    imm_2      value=0x18
    imm_3      value=0x19
    imm_5      value=0x21
    imm_10     value=0x23
    imm_99     value=0x27

字段 mreg2     bits=7:0
    ax         value=0x01
    bx         value=0x02
    cx         value=0x03
    dx         value=0x04
    imm_0      value=0x00
    imm_1      value=0x17
    imm_2      value=0x18
    imm_3      value=0x19
    imm_5      value=0x21
    imm_10     value=0x23
    imm_99     value=0x27

字段 mlabel    bits=7:0  type=immediate
