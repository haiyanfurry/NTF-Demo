; Hello World 程序 - 二进制编码 (十六进制格式)
; CPU: test_hello.hdr
;
; 01 nn  = print 'n' (n=ASCII字符)
; 02     = waitkey (等待按键)
; FF     = exit (退出)
; 11     = mov ax, ax
; 12     = mov ax, bx
; 00     = nop
;
01 48  ; print 'H'
01 65  ; print 'e'
01 6C  ; print 'l'
01 6C  ; print 'l'
01 6F  ; print 'o'
01 2C  ; print ','
01 20  ; print ' '
01 57  ; print 'W'
01 6F  ; print 'o'
01 72  ; print 'r'
01 6C  ; print 'l'
01 64  ; print 'd'
01 21  ; print '!'
02     ; waitkey
FF     ; exit
