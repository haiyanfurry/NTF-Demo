; ============================================
; RISC-V Lite CPU 定义 (演示: RISC-V RV32I 子集)
; ============================================
; 这是一个概念演示，展示 DSL 如何描述 RISC-V 风格架构。
; RISC-V RV32I 固定 32 位 (4 字节) 指令。
;
; R-type:   [31:25] funct7 | [24:20] rs2 | [19:15] rs1 | [14:12] funct3 | [11:7] rd | [6:0] opcode
; I-type:   [31:20] imm[11:0] | [19:15] rs1 | [14:12] funct3 | [11:7] rd | [6:0] opcode
; ============================================

arch "riscv-lite"
endian little
insn_size fixed 4

; ============================================
; 指令编码
; ============================================
; opcode = [6:0]
; R-type: opcode=0x33
指令 add       mask=0xFE00707F pattern=0x00000033  operands=rd_rtype,rs1_rtype,rs2_rtype
指令 sub       mask=0xFE00707F pattern=0x40000033  operands=rd_rtype,rs1_rtype,rs2_rtype
指令 xor       mask=0xFE00707F pattern=0x40330033  operands=rd_rtype,rs1_rtype,rs2_rtype

; I-type: opcode=0x13
指令 addi      mask=0x0000707F pattern=0x00000013  operands=rd_itype,rs1_itype,imm_itype

; Load: opcode=0x03
指令 lw        mask=0x0000707F pattern=0x00002003  operands=rd_itype,rs1_itype,imm_itype

; Store: opcode=0x23 (S-type)
指令 sw        mask=0x0000707F pattern=0x00002023  operands=rs2_stype,rs1_stype,imm_stype

; Branch: opcode=0x63 (B-type)
指令 beq       mask=0x0000707F pattern=0x00000063  operands=rs1_btype,rs2_btype,imm_btype

; ============================================
; 字段定义
; ============================================

; R-type 寄存器字段 [11:7] = rd, [19:15] = rs1, [24:20] = rs2
字段 rd_rtype   bits=11:7
    x0         value=00000
    ra         value=00001
    sp         value=00010
    gp         value=00011
    tp         value=00100
    t0         value=00101
    t1         value=00110
    t2         value=00111
    s0         value=01000
    s1         value=01001
    a0         value=01010
    a1         value=01011
    a2         value=01100
    a3         value=01101
    a4         value=01110
    a5         value=01111

字段 rs1_rtype  bits=19:15
    x0         value=00000
    ra         value=00001
    sp         value=00010
    gp         value=00011
    tp         value=00100
    t0         value=00101
    t1         value=00110
    t2         value=00111
    s0         value=01000
    s1         value=01001
    a0         value=01010
    a1         value=01011
    a2         value=01100
    a3         value=01101
    a4         value=01110
    a5         value=01111

字段 rs2_rtype  bits=24:20
    x0         value=00000
    ra         value=00001
    sp         value=00010
    gp         value=00011
    tp         value=00100
    t0         value=00101
    t1         value=00110
    t2         value=00111
    s0         value=01000
    s1         value=01001
    a0         value=01010
    a1         value=01011
    a2         value=01100
    a3         value=01101
    a4         value=01110
    a5         value=01111

; I-type 寄存器字段 [11:7] = rd, [19:15] = rs1
字段 rd_itype  bits=11:7
    x0         value=00000
    ...

字段 rs1_itype bits=19:15
    x0         value=00000
    ...

; I-type 立即数 [31:20] = imm[11:0]
字段 imm_itype bits=31:20  type=immediate  signed

; S-type 字段
字段 rs2_stype bits=24:20
    x0         value=00000
    ...

字段 rs1_stype bits=19:15
    x0         value=00000
    ...

; S-type 立即数: imm[11:5] = [31:25], imm[4:0] = [11:7]
字段 imm_stype bits=31:25  type=immediate  signed  ; 高位部分
                bits=11:7                         ; 低位部分 (拼接)

; B-type 字段
字段 rs1_btype bits=19:15
    x0         value=00000
    ...

字段 rs2_btype bits=24:20
    x0         value=00000
    ...

字段 imm_btype bits=31:25  type=immediate  signed  ; imm[12|10:5]
                bits=11:7                         ; imm[4:1|11]
