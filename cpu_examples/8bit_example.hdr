; ============================================
; 8-bit CPU 定义示例 (v2.0 重构版)
; ============================================
; 编码格式 (单字节指令):
;   Byte: [7:4] = opcode, [3:2] = dst, [1:0] = src
;   多字节指令: 首字节全匹配 + 后续字节
;
; 指令集:
;   0x0x → nop          (0000xxxx)
;   0x1x → mov dst, src (0001xxxx)
;   0x2x → add dst, src (0010xxxx)
;   0x3x → sub dst, src (0011xxxx)
;   0x4x → mul dst, src (0100xxxx)
;   0x5x → inc dst      (0101xxxx)
;   0x6x → dec dst      (0110xxxx)
;   0x7x → xor dst, src (0111xxxx)
;   0x80 → jmp addr     (2字节)
;   0x90 → push reg     (2字节)
;   0xA0 → pop reg      (2字节)
;   0xB0-0xFF → db 0xNN (未定义, 直接输出为数据)
; ============================================

; --- 全局配置 ---
arch "ntf-8bit-v2"
endian little
insn_size variable

; ============================================
; 指令编码表
; ============================================
; 单字节指令: mask=0xF0, 高4位匹配opcode
; 注意: mask 位越多优先级越高
;       nop 匹配 0x00-0x0F, mov 匹配 0x10-0x1F, 不会冲突

指令 nop       mask=0xF0 pattern=0x00
指令 mov       mask=0xF0 pattern=0x10  operands=dst,src
指令 add       mask=0xF0 pattern=0x20  operands=dst,src
指令 sub       mask=0xF0 pattern=0x30  operands=dst,src
指令 mul       mask=0xF0 pattern=0x40  operands=dst,src
指令 inc       mask=0xF0 pattern=0x50  operands=dst
指令 dec       mask=0xF0 pattern=0x60  operands=dst
指令 xor       mask=0xF0 pattern=0x70  operands=dst,src

; 2字节指令: mask=0xFF, 首字节全匹配
指令 jmp       mask=0xFF pattern=0x80  operands=target   size=2
指令 push      mask=0xFF pattern=0x90  operands=push_reg size=2
指令 pop       mask=0xFF pattern=0xA0  operands=pop_reg  size=2

; ============================================
; 操作数字段定义
; ============================================

; 目的寄存器字段 [3:2]
字段 dst       bits=3:2
    ax         value=00
    bx         value=01
    cx         value=10
    dx         value=11

; 源操作数字段 [1:0]
字段 src       bits=1:0
    ax         value=00
    bx         value=01
    imm_1      value=10
    imm_5      value=11

; 跳转目标地址 (第二字节)
字段 target    bits=7:0  type=immediate

; push 寄存器编码 (第二字节)
字段 push_reg  bits=7:0
    ax         value=0x00
    bx         value=0x01
    cx         value=0x02
    dx         value=0x03

; pop 寄存器编码 (第二字节)
字段 pop_reg   bits=7:0
    ax         value=0x00
    bx         value=0x01
    cx         value=0x02
    dx         value=0x03
