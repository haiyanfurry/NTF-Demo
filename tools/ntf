#!/bin/bash
# NTF Toolchain Wrapper
# Usage: ./ntf {build|run|disasm|asm} <file>
set -e
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJ_DIR="$(dirname "$SCRIPT_DIR")"
CPU_DEF="$PROJ_DIR/cpu_defs/8bit_example.hdr"

case "${1:-}" in
    build)
        # .ntf → assemble → .bin
        SRC="$2"
        OUT="${2%.ntf}"
        echo "=== Assembling $SRC → $OUT.bin ==="
        "$PROJ_DIR/bin/assembler" -c "$CPU_DEF" "$SRC" -o "$OUT.bin"
        echo "=== Wrapping $OUT.bin → $OUT (executable) ==="
        cat > "$OUT" << EOF
#!/bin/bash
exec "$PROJ_DIR/bin/ntfrun" "\$(dirname "\$0")/\$(basename "\$0").bin"
EOF
        cp "$OUT.bin" "$(dirname "$OUT")/" 2>/dev/null || true
        chmod +x "$OUT"
        echo "Done: $OUT"
        ;;
    run)
        SRC="$2"
        TMP="/tmp/ntf_$$.bin"
        "$PROJ_DIR/bin/assembler" -c "$CPU_DEF" "$SRC" -o "$TMP" 2>/dev/null
        "$PROJ_DIR/bin/ntfrun" "$TMP"
        rm -f "$TMP"
        ;;
    disasm)
        shift
        exec "$PROJ_DIR/bin/compiler" -c "$CPU_DEF" "$@"
        ;;
    asm)
        shift
        exec "$PROJ_DIR/bin/assembler" -c "$CPU_DEF" "$@"
        ;;
    *)
        echo "NTF Toolchain"
        echo "  ntf build <file.ntf>   - Compile to executable"
        echo "  ntf run   <file.ntf>   - Compile and run"
        echo "  ntf disasm <file.bin>  - Disassemble binary"
        echo "  ntf asm   <file.ntf>   - Assemble to .bin"
        ;;
esac
